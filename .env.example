# Configuración del servidor QR-Asistencia

# Puerto de escucha (Render lo asigna automáticamente)
PORT=3000

# 🌍 BASE DE DATOS EN LA NUBE (MONGODB ATLAS) - REQUERIDO
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/qr_asistencia?retryWrites=true&w=majority

# JWT Secret - CAMBIAR EN PRODUCCIÓN
JWT_SECRET=tu_clave_secreta_super_segura_aqui

# Admin Credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Entorno
NODE_ENV=production
